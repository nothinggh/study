with tab2:

    conn = sqlite3.connect(DB_PATH)

    df = pd.read_sql_query("SELECT * FROM BOM", conn)

    conn.close()

  

    col_search, col_btn1, col_btn2 = st.columns([3, 1, 1])

    with col_search:

        search_kw = st.text_input("검색어 입력 (모든 컬럼 대상)", "")

    if search_kw:

        mask = df.astype(str).apply(lambda x: x.str.contains(search_kw, case=False)).any(axis=1)

        df = df[mask]

  

    if "select_all" not in st.session_state:

        st.session_state.select_all = False

  

    with col_btn1:

        if st.button("전체 선택 / 해제"):

            st.session_state.select_all = not st.session_state.select_all

            st.rerun()

  

    if not df.empty:

        df.insert(0, "선택", st.session_state.select_all)

  

        edited_df = st.data_editor(

            df,

            column_config={

                "id": st.column_config.NumberColumn("ID", disabled=True),

                "선택": st.column_config.CheckboxColumn("선택", default=False)

            },

            hide_index=True,

            use_container_width=True

        )

  

        with col_btn2:

            if st.button("선택 삭제"):

                selected_ids = edited_df[edited_df["선택"] == True]["id"].tolist()

                if selected_ids:

                    conn = sqlite3.connect(DB_PATH)

                    c = conn.cursor()

                    c.executemany("DELETE FROM BOM WHERE id = ?", [(i,) for i in selected_ids])

                    conn.commit()

                    conn.close()

                    st.success("삭제되었습니다.")

                    st.rerun()

  

        if st.button("수정사항 저장"):

            conn = sqlite3.connect(DB_PATH)

            c = conn.cursor()

            for idx, row in edited_df.iterrows():

                c.execute("""

                    UPDATE BOM SET

                        user_id = ?, ship_no = ?, item_type = ?, material = ?,

                        size = ?, quantity = ?, weight = ?, price = ?,

                        order_date = ?, request_note = ?

                    WHERE id = ?

                """, (

                    row["user_id"], row["ship_no"], row["item_type"], row["material"],

                    row["size"], int(row["quantity"]), float(row["weight"]), float(row["price"]),

                    str(row["order_date"]), str(row["request_note"]), int(row["id"])

                ))

            conn.commit()

            conn.close()

            st.success("수정사항이 저장되었습니다.")

            st.rerun()

    else:

        st.info("조회된 데이터가 없습니다.")
