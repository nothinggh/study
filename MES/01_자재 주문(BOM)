tab1, tab2 = st.tabs(["1. 자재 주문 등록", "2. 전체 주문 관리"])

  

with tab1:

    col1, col2, col3, col4 = st.columns(4)

    with col1:

        user_id = st.text_input("주문자 ID")

        material = st.selectbox("재질", ["steel", "sus", "copper", "asbestos", "rubber"])

    with col2:

        ship_no = st.text_input("호선 번호")

        all_sizes = ["8A", "10A", "15A", "20A", "25A", "32A", "40A", "50A", "65A", "80A", "100A"]

        if material in ["steel", "sus"]:

            valid_sizes = [s for s in all_sizes if s not in ["8A", "10A"]]

        elif material == "copper":

            valid_sizes = ["8A", "10A"]

        else:

            valid_sizes = all_sizes

        selected_size = st.selectbox("Size", valid_sizes)

  

    with col3:

        item_type = st.selectbox("자재 종류", ["Pipe(6M)", "flange", "coupling", "bolt", "nut", "gasket", "elbow", "tee"])

        quantity = st.number_input("수량", min_value=1, value=1, step=1)

  

    with col4:

        order_date = st.date_input("주문 날짜", date.today())

        calc_weight = WEIGHT_DATA.get(selected_size, 0.0) if item_type == "Pipe(6M)" else 0.0

        calc_price = PRICE_DATA.get(item_type, {}).get(selected_size, 0)

        st.text_input("중량(개당/kg)", value=str(calc_weight), disabled=True)

        st.text_input("가격(개당/원)", value=str(calc_price), disabled=True)

  

    request_note = st.text_area("요청 사항", height=60)

  

    if st.button("등록"):

        if not user_id or not ship_no:

            st.error("주문자 ID와 호선 번호를 입력하세요.")

        else:

            conn = sqlite3.connect(DB_PATH)

            c = conn.cursor()

            c.execute("""

                INSERT INTO BOM (user_id, ship_no, item_type, material, size, quantity, weight, price, order_date, request_note)

                VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)

            """, (user_id, ship_no, item_type, material, selected_size, quantity, calc_weight, calc_price, str(order_date), request_note))

            conn.commit()

